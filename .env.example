# ============================================================
# .env.example — copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# .env is git-ignored and must NEVER be committed.
# ============================================================

# ── App ──────────────────────────────────────────────────────
# Base URL of the target Orbis instance
AVERTEX_BASE_URL=https://orbis-dev.savetime.com/

# Maximum automation steps before the run is force-stopped
AVERTEX_MAX_STEPS=60

# ── Credentials ──────────────────────────────────────────────
# Your Orbis login email
AVERTEX_EMAIL=suraj.kadam@ascentt.com

# Your Orbis login password  (required — no default)
AVERTEX_PASSWORD=$Sara$1001

# ── Browser ──────────────────────────────────────────────────
# Set to "false" to watch the browser window during development
HEADLESS=false
