# ============================================================
# .env.example — A-Vertex Automation Tool
#
# Copy this file to .env and fill in your real values.
# .env is git-ignored and must NEVER be committed.
#
#   Windows:  copy .env.example .env
#   Linux:    cp  .env.example  .env
# ============================================================

# ── Credentials (required) ───────────────────────────────────
AVERTEX_EMAIL=""
AVERTEX_PASSWORD=""

# ── App URL (optional — override only if needed) ─────────────
AVERTEX_BASE_URL="https://orbis-dev.savetime.com/"

# ── Browser (optional) ───────────────────────────────────────
# Set to false for local development (shows browser window).
# Leave true (or unset) for CI/production (headless, no display needed).
HEADLESS=false

# ── Misc (optional) ──────────────────────────────────────────
AVERTEX_MAX_STEPS=60
